@page "/"
@using BlazorApp.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject NavigationManager NavManager

<PageTitle>Головна - Дашборд</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-dark">👋 Вітаємо в панелі управління!</h2>
            <p class="text-muted mb-0">Коротка зводка по вашому бізнесу оренди на сьогодні.</p>
        </div>
        <div>
            <a href="/inventory" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-geo-alt me-2"></i>Відкрити карту
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white;">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h6 class="text-uppercase fw-bold opacity-75 mb-0">Загальний дохід</h6>
                        <i class="bi bi-wallet2 fs-3 opacity-50"></i>
                    </div>
                    <div>
                        <h2 class="fw-bold mb-0">@totalRevenue.ToString("N0") ₴</h2>
                        <small class="opacity-75">З усіх завершених поїздок</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, #2F80ED 0%, #56CCF2 100%); color: white;">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h6 class="text-uppercase fw-bold opacity-75 mb-0">В дорозі</h6>
                        <i class="bi bi-bicycle fs-3 opacity-50"></i>
                    </div>
                    <div>
                        <h2 class="fw-bold mb-0">@activeRentals</h2>
                        <small class="opacity-75">Транспорту зараз в оренді</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, #8E2DE2 0%, #4A00E0 100%); color: white;">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h6 class="text-uppercase fw-bold opacity-75 mb-0">База клієнтів</h6>
                        <i class="bi bi-people fs-3 opacity-50"></i>
                    </div>
                    <div>
                        <h2 class="fw-bold mb-0">@totalUsers</h2>
                        <small class="opacity-75">Зареєстрованих користувачів</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, #FF416C 0%, #FF4B2B 100%); color: white;">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h6 class="text-uppercase fw-bold opacity-75 mb-0">Потребують уваги</h6>
                        <i class="bi bi-exclamation-triangle fs-3 opacity-50"></i>
                    </div>
                    <div>
                        <h2 class="fw-bold mb-0">@(brokenTransports + unresolvedIssues)</h2>
                        <small class="opacity-75">@brokenTransports в ремонті, @unresolvedIssues нових скарг</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white p-4 border-bottom-0">
                    <h5 class="fw-bold mb-0">Статус Автопарку</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-success fw-bold"><i class="bi bi-check-circle me-2"></i>Доступні</span>
                        <span class="fw-bold">@availableTransports</span>
                    </div>
                    <div class="progress mb-4" style="height: 10px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: @(GetPercentage(availableTransports))%"></div>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-primary fw-bold"><i class="bi bi-stopwatch me-2"></i>В оренді</span>
                        <span class="fw-bold">@activeRentals</span>
                    </div>
                    <div class="progress mb-4" style="height: 10px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: @(GetPercentage(activeRentals))%"></div>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-danger fw-bold"><i class="bi bi-tools me-2"></i>На обслуговуванні</span>
                        <span class="fw-bold">@brokenTransports</span>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-danger" role="progressbar" style="width: @(GetPercentage(brokenTransports))%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-dark text-white text-center p-4 d-flex flex-column justify-content-center align-items-center">
                
                @if (isDbConnected)
                {
                    <i class="bi bi-database-check mb-2" style="font-size: 2.5rem; color: #38ef7d;"></i>
                    <h5 class="fw-bold text-success mb-3">База Даних: Підключено</h5>
                }
                else
                {
                    <i class="bi bi-database-x mb-2" style="font-size: 2.5rem; color: #ff4b2b;"></i>
                    <h5 class="fw-bold text-danger mb-3">Помилка підключення до БД!</h5>
                }

                <p class="text-white-50 mb-2 small">Демо-сканування (оренда вільного транспорту):</p>
                <div class="bg-white p-2 rounded-3 mb-4 d-inline-block">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=130x130&data=@($"{NavManager.BaseUri}inventory?rent={demoTransportId}")" alt="QR Code" style="width: 130px; height: 130px;" />
                </div>

                <a href="/admin" class="btn btn-outline-light btn-sm rounded-pill px-4 mt-auto">
                    <i class="bi bi-gear me-2"></i>Перейти в Адмін-панель
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isDbConnected = false;
    private int totalUsers = 0;
    private int totalTransports = 0;
    private int activeRentals = 0;
    private int brokenTransports = 0;
    private int availableTransports = 0;
    private double totalRevenue = 0;
    private int unresolvedIssues = 0;
    
    // ID вільного транспорту для QR-коду
    private int demoTransportId = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isDbConnected = await Db.Database.CanConnectAsync();
        }
        catch
        {
            isDbConnected = false;
        }

        if (isDbConnected)
        {
            totalUsers = await Db.Users.CountAsync();
            
            var allTransports = await Db.Transports.ToListAsync();
            totalTransports = allTransports.Count;
            
            var sessions = await Db.RentalSessions.ToListAsync();
            activeRentals = sessions.Count(s => string.IsNullOrEmpty(s.EndTime));
            
            totalRevenue = sessions.Where(s => s.TotalCost.HasValue).Sum(s => s.TotalCost.Value);
            
            brokenTransports = allTransports.Count(t => t.StateCode != null && (t.StateCode.ToLower().Contains("рем") || t.StateCode.ToLower().Contains("maint")));
            availableTransports = totalTransports - activeRentals - brokenTransports;

            unresolvedIssues = await Db.IssueReports.CountAsync(i => !i.IsResolved);

            // Знаходимо перший-ліпший ДОСТУПНИЙ транспорт для демо-QR-коду
            var freeTransport = allTransports.FirstOrDefault(t => 
                !sessions.Any(s => s.TransportId == t.Id && string.IsNullOrEmpty(s.EndTime)) && 
                !(t.StateCode != null && (t.StateCode.ToLower().Contains("рем") || t.StateCode.ToLower().Contains("maint"))));
            
            if (freeTransport != null)
            {
                demoTransportId = freeTransport.Id;
            }
        }
    }

    private int GetPercentage(int value)
    {
        if (totalTransports == 0) return 0;
        return (int)Math.Round((double)value / totalTransports * 100);
    }
}