@page "/"
@using BlazorApp.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db

<PageTitle>Головна - Оренда</PageTitle>

<h1>🚲 Система прокату транспорту</h1>
<p>Ласкаво просимо до панелі керування орендою велосипедів та електросамокатів.</p>

@if (isDbConnected == null)
{
    <div class="alert alert-warning">⏳ Перевірка підключення до бази даних...</div>
}
else if (isDbConnected == true)
{
    <div class="alert alert-success"><strong>✅ Успіх:</strong> База даних SQLite успішно підключена!</div>
}
else
{
    <div class="alert alert-danger"><strong>❌ Помилка:</strong> Не вдалося підключитися до бази.</div>
}

<a href="/inventory" class="btn btn-primary">Перейти до інвентарю</a>

@code {
    private bool? isDbConnected;

    protected override async Task OnInitializedAsync()
    {
        // Фізично перевіряємо, чи база відповідає
        isDbConnected = await Db.Database.CanConnectAsync();
    }
}