@page "/register"
@rendermode InteractiveServer
@using BlazorApp.Data
@using BlazorApp.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db

<PageTitle>Реєстрація</PageTitle>

<style>
    .sortable-header {
        cursor: pointer;
        user-select: none;
        transition: background-color 0.2s;
    }
    .sortable-header:hover {
        background-color: #f8f9fa;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Реєстрація нового користувача</h2>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 rounded-4 bg-light p-4 h-100">
            <h5 class="fw-bold text-primary mb-4">Створити акаунт</h5>
            
            <div class="mb-3">
                <label class="form-label text-muted small fw-bold">Ваше ім'я або Нікнейм:</label>
                <input type="text" class="form-control form-control-lg rounded-3" placeholder="Введіть ім'я..." @bind="newName" />
            </div>
            
            <div class="mb-4">
                <label class="form-label text-muted small fw-bold">Початковий баланс (грн):</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">₴</span>
                    <input type="number" class="form-control form-control-lg border-start-0 ps-0" @bind="newBalance" />
                </div>
                <div class="form-text text-success mt-2 fw-bold">Даруємо 100 грн новим клієнтам!</div>
            </div>

            <button class="btn btn-success btn-lg w-100 rounded-pill shadow-sm fw-bold mt-auto" @onclick="RegisterUser" disabled="@string.IsNullOrWhiteSpace(newName)">
                Зареєструватися
            </button>
            
            @if (showSuccess)
            {
                <div class="alert alert-success mt-3 mb-0 rounded-3 py-2 text-center">
                    Клієнта <strong>@lastAddedName</strong> успішно додано!
                </div>
            }
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">
            <div class="card-header bg-white p-4 border-bottom-0">
                <h5 class="fw-bold mb-0 text-dark">Список клієнтів у базі</h5>
            </div>
            <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th class="sortable-header px-4" @onclick="@(() => Sort("ID"))">
                                ID <span class="bi @GetSortIcon("ID") ms-1 text-muted" style="font-size: 0.8rem;"></span>
                            </th>
                            <th class="sortable-header" @onclick="@(() => Sort("Name"))">
                                Ім'я <span class="bi @GetSortIcon("Name") ms-1 text-muted" style="font-size: 0.8rem;"></span>
                            </th>
                            <th class="sortable-header text-end px-4" @onclick="@(() => Sort("Balance"))">
                                Баланс <span class="bi @GetSortIcon("Balance") ms-1 text-muted" style="font-size: 0.8rem;"></span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!GetSortedUsers().Any())
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">Немає зареєстрованих клієнтів.</td></tr>
                        }
                        else
                        {
                            @foreach (var u in GetSortedUsers())
                            {
                                <tr>
                                    <td class="px-4 text-muted">#@u.Id</td>
                                    <td><strong>@u.Name</strong></td>
                                    <td class="text-end px-4">
                                        <span class="badge @(u.Balance < 0 ? "bg-danger" : "bg-primary") rounded-pill px-3 py-2">
                                            @u.Balance грн
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<User> users = new();
    private string newName = "";
    private double newBalance = 100;
    
    private bool showSuccess = false;
    private string lastAddedName = "";

    // Змінні сортування
    private string sortCol = "ID";
    private bool sortAsc = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        users = await Db.Users.ToListAsync();
    }

    // Логіка сортування
    private void Sort(string col)
    {
        if (sortCol == col) sortAsc = !sortAsc;
        else { sortCol = col; sortAsc = true; }
    }

    private string GetSortIcon(string colName)
    {
        if (sortCol != colName) return "bi-arrow-down-up";
        return sortAsc ? "bi-arrow-up" : "bi-arrow-down";
    }

    private IEnumerable<User> GetSortedUsers()
    {
        return sortCol switch {
            "Name" => sortAsc ? users.OrderBy(u => u.Name) : users.OrderByDescending(u => u.Name),
            "Balance" => sortAsc ? users.OrderBy(u => u.Balance) : users.OrderByDescending(u => u.Balance),
            _ => sortAsc ? users.OrderBy(u => u.Id) : users.OrderByDescending(u => u.Id)
        };
    }

    private async Task RegisterUser()
    {
        if (!string.IsNullOrWhiteSpace(newName))
        {
            var user = new User { Name = newName, Balance = newBalance };
            Db.Users.Add(user);
            await Db.SaveChangesAsync();
            
            lastAddedName = newName;
            showSuccess = true;
            newName = "";
            newBalance = 100;
            
            await LoadUsers();
            _ = Task.Delay(3000).ContinueWith(_ => { showSuccess = false; InvokeAsync(StateHasChanged); });
        }
    }
}