@page "/admin"
@rendermode InteractiveServer
@using BlazorApp.Data
@using BlazorApp.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject NavigationManager NavManager

<PageTitle>Керування базою</PageTitle>

<style>
    .sortable-header { cursor: pointer; user-select: none; transition: background-color 0.2s; }
    .sortable-header:hover { background-color: #343a40; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Панель керування базою даних (CRUD)</h2>
</div>

<ul class="nav nav-pills mb-4 gap-2">
    <li class="nav-item"><button class="nav-link @(activeTab == "users" ? "active shadow-sm" : "bg-light text-dark border")" @onclick="@(() => activeTab = "users")">Користувачі</button></li>
    <li class="nav-item"><button class="nav-link @(activeTab == "transport" ? "active shadow-sm" : "bg-light text-dark border")" @onclick="@(() => activeTab = "transport")">Автопарк</button></li>
    <li class="nav-item"><button class="nav-link @(activeTab == "sessions" ? "active shadow-sm" : "bg-light text-dark border")" @onclick="@(() => activeTab = "sessions")">Усі поїздки</button></li>
    <li class="nav-item"><button class="nav-link @(activeTab == "issues" ? "active btn-danger shadow-sm" : "bg-light text-danger border")" @onclick="@(() => activeTab = "issues")">Скарги клієнтів @if(unresolvedIssues > 0){<span class="badge bg-danger ms-1">@unresolvedIssues</span>}</button></li>
</ul>

@if (activeTab == "users")
{
    @if (editingUser != null)
    {
        <div class="card p-4 mb-4 border-0 shadow-sm rounded-4 bg-light">
            <h5 class="fw-bold text-primary mb-3">Редагування користувача #@editingUser.Id</h5>
            <div class="row g-3">
                <div class="col-md-5"><label class="form-label text-muted small">Ім'я:</label><input class="form-control" @bind="editingUser.Name" /></div>
                <div class="col-md-4"><label class="form-label text-muted small">Баланс (грн):</label><input type="number" step="0.01" class="form-control" @bind="editingUser.Balance" /></div>
                <div class="col-md-3 d-flex align-items-end"><button class="btn btn-success w-100 me-2" @onclick="SaveUser">Зберегти</button><button class="btn btn-outline-secondary w-100" @onclick="() => editingUser = null">Скасувати</button></div>
            </div>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-5">
        <div class="card-header bg-white p-4 d-flex justify-content-between align-items-center border-bottom-0">
            <h5 class="fw-bold mb-0 text-dark">Клієнтська база</h5>
            <div class="d-flex gap-3" style="max-width: 500px; width: 100%;">
                <input type="text" class="form-control rounded-pill px-3" placeholder="Пошук за ім'ям..." @bind="userSearchQuery" @bind:event="oninput" />
                <select class="form-select rounded-pill px-3" @bind="userFilter" style="max-width: 200px;"><option value="all">Усі клієнти</option><option value="positive">З грошима (&gt; 0)</option><option value="negative">Боржники (&lt; 0)</option></select>
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="sortable-header px-4" @onclick="@(() => SortUsers("ID"))">ID <span class="bi @GetSortIcon(userSortCol, userSortAsc, "ID", false) ms-1 text-white-50"></span></th>
                        <th class="sortable-header" @onclick="@(() => SortUsers("Name"))">Ім'я <span class="bi @GetSortIcon(userSortCol, userSortAsc, "Name", false) ms-1 text-white-50"></span></th>
                        <th class="sortable-header" @onclick="@(() => SortUsers("Balance"))">Баланс <span class="bi @GetSortIcon(userSortCol, userSortAsc, "Balance", false) ms-1 text-white-50"></span></th>
                        <th class="text-end px-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!GetSortedUsers().Any()) { <tr><td colspan="4" class="text-center text-muted py-4">За вашим запитом нікого не знайдено.</td></tr> }
                    else { @foreach (var u in GetSortedUsers()) { <tr><td class="px-4 text-muted">@u.Id</td><td><strong>@u.Name</strong></td><td><span class="badge @(u.Balance < 0 ? "bg-danger" : "bg-success") rounded-pill px-3 py-2">@u.Balance грн</span></td><td class="text-end px-4"><button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-2" @onclick="() => editingUser = u">Редагувати</button><button class="btn btn-sm btn-outline-danger rounded-pill px-3" @onclick="() => DeleteUser(u)">Видалити</button></td></tr> } }
                </tbody>
            </table>
        </div>
    </div>
}

@if (activeTab == "transport")
{
    @if (editingTransport != null)
    {
        <div class="card p-4 mb-4 border-0 shadow-sm rounded-4 bg-light">
            <h5 class="fw-bold text-primary mb-3">Редагування транспорту #@editingTransport.Id</h5>
            <div class="row g-3">
                <div class="col-md-3"><label class="form-label text-muted small">Держ. номер:</label><input class="form-control" @bind="editingTransport.StateCode" /></div>
                @if (editingTransport is Scooter s) { <div class="col-md-2"><label class="form-label text-muted small">Батарея (%):</label><input type="number" class="form-control" @bind="s.BatteryLevel" /></div><div class="col-md-2"><label class="form-label text-muted small">Двигун (Вт):</label><input type="number" class="form-control" @bind="s.MotorPower" /></div> }
                else if (editingTransport is Bicycle b) { <div class="col-md-2"><label class="form-label text-muted small">Рама:</label><input class="form-control" @bind="b.FrameSize" /></div><div class="col-md-2 d-flex align-items-center mt-4 pt-2"><div class="form-check"><input type="checkbox" class="form-check-input" @bind="b.HasBasket" id="basketCheck" /><label class="form-check-label text-muted" for="basketCheck">Є кошик</label></div></div> }
                <div class="col-md-5 d-flex align-items-end"><button class="btn btn-primary w-50 me-2" @onclick="SaveTransport">Зберегти</button><button class="btn btn-outline-secondary w-50" @onclick="() => editingTransport = null">Скасувати</button></div>
            </div>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-5">
        <div class="card-header bg-white p-4 d-flex justify-content-between align-items-center border-bottom-0">
            <h5 class="fw-bold mb-0 text-dark">Керування інвентарем</h5>
            <div class="d-flex gap-3" style="max-width: 500px; width: 100%;">
                <input type="text" class="form-control rounded-pill px-3" placeholder="Пошук за держ. номером..." @bind="transportSearchQuery" @bind:event="oninput" />
                <select class="form-select rounded-pill px-3" @bind="transportFilter" style="max-width: 210px;"><option value="all">Увесь транспорт</option><option value="available">Доступні</option><option value="in_use">В оренді</option><option value="maintenance">На обслуговуванні</option></select>
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="sortable-header px-4" @onclick="@(() => SortTransports("ID"))">ID <span class="bi @GetSortIcon(transportSortCol, transportSortAsc, "ID", true) ms-1 text-white-50"></span></th>
                        <th class="sortable-header" @onclick="@(() => SortTransports("Type"))">Тип <span class="bi @GetSortIcon(transportSortCol, transportSortAsc, "Type", true) ms-1 text-white-50"></span></th>
                        <th class="sortable-header" @onclick="@(() => SortTransports("StateCode"))">Держ. номер <span class="bi @GetSortIcon(transportSortCol, transportSortAsc, "StateCode", true) ms-1 text-white-50"></span></th>
                        <th>Характеристики</th>
                        <th class="sortable-header" @onclick="@(() => SortTransports("Status"))">Статус <span class="bi @GetSortIcon(transportSortCol, transportSortAsc, "Status", true) ms-1 text-white-50"></span></th>
                        <th class="text-end px-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!GetSortedTransports().Any()) { <tr><td colspan="6" class="text-center text-muted py-4">Транспорт не знайдено.</td></tr> }
                    else { @foreach (var t in GetSortedTransports()) { <tr>
                        <td class="px-4 text-muted">@t.Id</td><td>@(t is Scooter ? "Самокат" : "Велосипед")</td><td><span class="badge bg-light text-dark border px-2 py-1">@t.StateCode</span></td>
                        <td>@if (t is Scooter s) { <small class="text-muted">Бат: <strong class="text-success">@s.BatteryLevel%</strong>, @s.MotorPower Вт</small> } else if (t is Bicycle b) { <small class="text-muted">Рама: <strong>@b.FrameSize</strong>, Кошик: @(b.HasBasket ? "Так" : "Ні")</small> }</td>
                        <td>@{ bool isInUse = sessions.Any(rs => rs.TransportId == t.Id && string.IsNullOrEmpty(rs.EndTime)); bool isMaintenance = t.StateCode != null && (t.StateCode.ToLower().Contains("рем") || t.StateCode.ToLower().Contains("maint")); }
                            @if (isInUse) { <span class="badge bg-danger rounded-pill px-3">В оренді</span> } else if (isMaintenance) { <span class="badge bg-warning text-dark rounded-pill px-3">Обслуговування</span> } else { <span class="badge bg-success rounded-pill px-3">Доступно</span> }
                            <div class="mt-2"><a href="https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=@($"{NavManager.BaseUri}inventory?rent={t.Id}")" target="_blank" class="badge bg-dark text-decoration-none rounded-pill px-2">QR-Код</a></div>
                        </td>
                        <td class="text-end px-4">
                            <button class="btn btn-sm @(isMaintenance ? "btn-success" : "btn-warning text-dark") rounded-pill px-3 me-2" disabled="@isInUse" @onclick="() => ToggleMaintenance(t)">@(isMaintenance ? "Полагодити" : "В ремонт")</button>
                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-2" @onclick="() => editingTransport = t">Ред.</button><button class="btn btn-sm btn-outline-danger rounded-pill px-3" disabled="@isInUse" @onclick="() => DeleteTransport(t)">Списати</button>
                        </td>
                    </tr> } }
                </tbody>
            </table>
        </div>
    </div>
}

@if (activeTab == "sessions")
{
    @if (editingSession != null)
    {
        <div class="card p-4 mb-4 border-0 shadow-sm rounded-4 bg-light">
            <h5 class="fw-bold text-primary mb-3">Редагування поїздки #@editingSession.Id</h5>
            <div class="row g-3">
                <div class="col-md-3"><label class="form-label text-muted small">Час початку:</label><input class="form-control" @bind="editingSession.StartTime" /></div>
                <div class="col-md-3"><label class="form-label text-muted small">Час фінішу:</label><input class="form-control" @bind="editingSession.EndTime" /></div>
                <div class="col-md-2"><label class="form-label text-muted small">Вартість (грн):</label><input type="number" step="0.01" class="form-control" @bind="editingSession.TotalCost" /></div>
                <div class="col-md-4 d-flex align-items-end"><button class="btn btn-info w-50 me-2 text-white" @onclick="SaveSession">Зберегти</button><button class="btn btn-outline-secondary w-50" @onclick="() => editingSession = null">Скасувати</button></div>
            </div>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-5">
        <div class="card-header bg-white p-4 d-flex justify-content-between align-items-center border-bottom-0">
            <h5 class="fw-bold mb-0 text-dark">Історія всіх поїздок</h5>
            <div class="d-flex gap-3" style="max-width: 500px; width: 100%;">
                <input type="text" class="form-control rounded-pill px-3" placeholder="Пошук клієнта/транспорту..." @bind="sessionSearchQuery" @bind:event="oninput" />
                <select class="form-select rounded-pill px-3" @bind="sessionFilter" style="max-width: 210px;"><option value="all">Усі поїздки</option><option value="active">В дорозі</option><option value="completed">Завершено</option></select>
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="sortable-header px-4" @onclick="@(() => SortSessions("ID"))">ID <span class="bi @GetSortIcon(sessionSortCol, sessionSortAsc, "ID", false) ms-1 text-white-50"></span></th>
                        <th class="sortable-header" @onclick="@(() => SortSessions("User"))">Клієнт / Транспорт <span class="bi @GetSortIcon(sessionSortCol, sessionSortAsc, "User", false) ms-1 text-white-50"></span></th>
                        <th class="sortable-header" @onclick="@(() => SortSessions("Time"))">Період <span class="bi @GetSortIcon(sessionSortCol, sessionSortAsc, "Time", false) ms-1 text-white-50"></span></th>
                        <th class="sortable-header" @onclick="@(() => SortSessions("Cost"))">Дохід <span class="bi @GetSortIcon(sessionSortCol, sessionSortAsc, "Cost", false) ms-1 text-white-50"></span></th>
                        <th class="text-end px-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!GetSortedSessions().Any()) { <tr><td colspan="5" class="text-center text-muted py-4">Поїздок не знайдено.</td></tr> }
                    else { @foreach (var s in GetSortedSessions()) { <tr><td class="px-4 text-muted">@s.Id</td><td><strong>@(s.User?.Name ?? "Видалений клієнт")</strong><br><span class="badge bg-light text-dark border px-2 mt-1">@(s.Transport?.StateCode ?? "Списаний транспорт")</span></td><td><span class="text-muted small">@s.StartTime &mdash; @(string.IsNullOrEmpty(s.EndTime) ? "В дорозі" : s.EndTime)</span></td><td>@if (string.IsNullOrEmpty(s.EndTime)) { <span class="badge bg-warning text-dark rounded-pill px-3">В процесі</span> } else { <strong class="text-success">@(s.TotalCost?.ToString() ?? "0") грн</strong> }</td><td class="text-end px-4"><button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-2" @onclick="() => editingSession = s">Редагувати</button><button class="btn btn-sm btn-outline-danger rounded-pill px-3" @onclick="() => DeleteSession(s)">Видалити</button></td></tr> } }
                </tbody>
            </table>
        </div>
    </div>
}

@if (activeTab == "issues")
{
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-5">
        <div class="card-header bg-white p-4 border-bottom-0">
            <h5 class="fw-bold mb-0 text-dark">Скарги на транспорт</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="sortable-header px-4" @onclick="@(() => SortIssues("ID"))">ID <span class="bi @GetSortIcon(issueSortCol, issueSortAsc, "ID", false) ms-1 text-white-50"></span></th>
                        <th class="sortable-header" @onclick="@(() => SortIssues("Transport"))">Транспорт <span class="bi @GetSortIcon(issueSortCol, issueSortAsc, "Transport", false) ms-1 text-white-50"></span></th>
                        <th>Опис проблеми</th>
                        <th class="sortable-header" @onclick="@(() => SortIssues("Time"))">Час скарги <span class="bi @GetSortIcon(issueSortCol, issueSortAsc, "Time", false) ms-1 text-white-50"></span></th>
                        <th class="sortable-header" @onclick="@(() => SortIssues("Status"))">Статус <span class="bi @GetSortIcon(issueSortCol, issueSortAsc, "Status", false) ms-1 text-white-50"></span></th>
                        <th class="text-end px-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!GetSortedIssues().Any()) { <tr><td colspan="6" class="text-center text-muted py-4">Немає жодної скарги. Усе працює ідеально!</td></tr> }
                    else { @foreach (var r in GetSortedIssues()) { 
                        <tr>
                            <td class="px-4 text-muted">@r.Id</td>
                            <td><span class="badge bg-secondary border">@r.TransportStateCode</span></td>
                            <td style="max-width: 300px; white-space: normal;">@r.Description</td>
                            <td><span class="text-muted small">@r.ReportTime</span></td>
                            <td>
                                @if (r.IsResolved) { <span class="badge bg-success rounded-pill px-3">Вирішено</span> }
                                else { <span class="badge bg-danger rounded-pill px-3">Очікує перевірки</span> }
                            </td>
                            <td class="text-end px-4">
                                @if (!r.IsResolved) {
                                    <button class="btn btn-sm btn-warning text-dark rounded-pill px-3 me-2 shadow-sm fw-bold" @onclick="() => SendToMaintenanceFromIssue(r)">На ремонт</button>
                                    
                                    <button class="btn btn-sm btn-success rounded-pill px-3 me-2" @onclick="() => ResolveIssue(r)">Відмітити як вирішене</button>
                                }
                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3" @onclick="() => DeleteIssue(r)">Видалити</button>
                            </td>
                        </tr> } 
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private string activeTab = "users"; 
    private List<User> users = new(); private List<Transport> transports = new(); private List<RentalSession> sessions = new(); private List<IssueReport> issueReports = new();
    private User? editingUser; private Transport? editingTransport; private RentalSession? editingSession;
    
    private int unresolvedIssues => issueReports.Count(r => !r.IsResolved);

    protected override async Task OnInitializedAsync() => await LoadData();
    private async Task LoadData() { 
        users = await Db.Users.ToListAsync(); 
        transports = await Db.Transports.ToListAsync(); 
        sessions = await Db.RentalSessions.Include(s => s.User).Include(s => s.Transport).ToListAsync(); 
        issueReports = await Db.IssueReports.ToListAsync();
    }

    // КОРИСТУВАЧІ
    private string userSearchQuery = ""; private string userFilter = "all"; private string userSortCol = "ID"; private bool userSortAsc = true;
    private void SortUsers(string col) { if(userSortCol == col) userSortAsc = !userSortAsc; else { userSortCol = col; userSortAsc = true; } }
    private IEnumerable<User> GetSortedUsers() {
        var q = users.Where(u => (stringIsNullOrWhiteSpace(userSearchQuery) || (u.Name != null && u.Name.ToLower().Contains(userSearchQuery.ToLower()))) && (userFilter == "all" || (userFilter == "positive" && u.Balance > 0) || (userFilter == "negative" && u.Balance < 0)));
        return userSortCol switch { "Name" => userSortAsc ? q.OrderBy(u => u.Name) : q.OrderByDescending(u => u.Name), "Balance" => userSortAsc ? q.OrderBy(u => u.Balance) : q.OrderByDescending(u => u.Balance), _ => userSortAsc ? q.OrderBy(u => u.Id) : q.OrderByDescending(u => u.Id) };
    }

    // ТРАНСПОРТ
    private string transportSearchQuery = ""; private string transportFilter = "all"; private string transportSortCol = "ID"; private bool transportSortAsc = true;
    private int transportStatusSortState = 0; 
    
    private void SortTransports(string col) { if(transportSortCol == col) { if (col == "Status") transportStatusSortState = (transportStatusSortState + 1) % 3; else transportSortAsc = !transportSortAsc; } else { transportSortCol = col; transportSortAsc = true; transportStatusSortState = 0; } }

    private int GetTransportStatusPriority(Transport t) {
        bool isInUse = sessions.Any(s => s.TransportId == t.Id && string.IsNullOrEmpty(s.EndTime));
        bool isMaintenance = t.StateCode != null && (t.StateCode.ToLower().Contains("рем") || t.StateCode.ToLower().Contains("maint"));
        if (transportStatusSortState == 0) { if (!isInUse && !isMaintenance) return 1; if (isInUse) return 2; return 3; }
        else if (transportStatusSortState == 1) { if (isInUse) return 1; if (isMaintenance) return 2; return 3; }
        else { if (isMaintenance) return 1; if (!isInUse && !isMaintenance) return 2; return 3; }
    }

    private IEnumerable<Transport> GetSortedTransports() {
        var q = transports.Where(t => (stringIsNullOrWhiteSpace(transportSearchQuery) || (t.StateCode != null && t.StateCode.ToLower().Contains(transportSearchQuery.ToLower()))) && (transportFilter == "all" || (transportFilter == "in_use" && sessions.Any(s => s.TransportId == t.Id && string.IsNullOrEmpty(s.EndTime))) || (transportFilter == "maintenance" && t.StateCode != null && (t.StateCode.ToLower().Contains("рем") || t.StateCode.ToLower().Contains("maint"))) || (transportFilter == "available" && !sessions.Any(s => s.TransportId == t.Id && string.IsNullOrEmpty(s.EndTime)) && !(t.StateCode != null && (t.StateCode.ToLower().Contains("рем") || t.StateCode.ToLower().Contains("maint"))))));
        return transportSortCol switch { "Type" => transportSortAsc ? q.OrderBy(t => t.GetType().Name).ThenBy(t => t.Id) : q.OrderByDescending(t => t.GetType().Name).ThenBy(t => t.Id), "StateCode" => transportSortAsc ? q.OrderBy(t => t.StateCode).ThenBy(t => t.Id) : q.OrderByDescending(t => t.StateCode).ThenBy(t => t.Id), "Status" => q.OrderBy(t => GetTransportStatusPriority(t)).ThenBy(t => t.Id), _ => transportSortAsc ? q.OrderBy(t => t.Id) : q.OrderByDescending(t => t.Id) };
    }

    // СЕАНСИ
    private string sessionSearchQuery = ""; private string sessionFilter = "all"; private string sessionSortCol = "ID"; private bool sessionSortAsc = false; 
    private void SortSessions(string col) { if(sessionSortCol == col) sessionSortAsc = !sessionSortAsc; else { sessionSortCol = col; sessionSortAsc = true; } }
    private IEnumerable<RentalSession> GetSortedSessions() {
        var q = sessions.Where(s => (stringIsNullOrWhiteSpace(sessionSearchQuery) || (s.User?.Name != null && s.User.Name.ToLower().Contains(sessionSearchQuery.ToLower())) || (s.Transport?.StateCode != null && s.Transport.StateCode.ToLower().Contains(sessionSearchQuery.ToLower()))) && (sessionFilter == "all" || (sessionFilter == "active" && string.IsNullOrEmpty(s.EndTime)) || (sessionFilter == "completed" && !string.IsNullOrEmpty(s.EndTime))));
        return sessionSortCol switch { "User" => sessionSortAsc ? q.OrderBy(s => s.User != null ? s.User.Name : "").ThenBy(s => s.Transport != null ? s.Transport.StateCode : "") : q.OrderByDescending(s => s.User != null ? s.User.Name : "").ThenByDescending(s => s.Transport != null ? s.Transport.StateCode : ""), "Time" => sessionSortAsc ? q.OrderBy(s => s.StartTime) : q.OrderByDescending(s => s.StartTime), "Cost" => sessionSortAsc ? q.OrderBy(s => s.TotalCost ?? 0) : q.OrderByDescending(s => s.TotalCost ?? 0), _ => sessionSortAsc ? q.OrderBy(s => s.Id) : q.OrderByDescending(s => s.Id) };
    }

    // СКАРГИ (Сортування)
    private string issueSortCol = "Status"; 
    private bool issueSortAsc = true;
    
    private void SortIssues(string col) { if(issueSortCol == col) issueSortAsc = !issueSortAsc; else { issueSortCol = col; issueSortAsc = true; } }
    
    private IEnumerable<IssueReport> GetSortedIssues() {
        var q = issueReports.AsEnumerable();
        return issueSortCol switch {
            "Transport" => issueSortAsc ? q.OrderBy(r => r.TransportStateCode).ThenByDescending(r => r.Id) : q.OrderByDescending(r => r.TransportStateCode).ThenByDescending(r => r.Id),
            "Time" => issueSortAsc ? q.OrderBy(r => r.ReportTime).ThenByDescending(r => r.Id) : q.OrderByDescending(r => r.ReportTime).ThenByDescending(r => r.Id),
            "Status" => issueSortAsc ? q.OrderBy(r => r.IsResolved).ThenByDescending(r => r.Id) : q.OrderByDescending(r => r.IsResolved).ThenByDescending(r => r.Id),
            "ID" => issueSortAsc ? q.OrderBy(r => r.Id) : q.OrderByDescending(r => r.Id),
            _ => q.OrderBy(r => r.IsResolved).ThenByDescending(r => r.Id)
        };
    }

    // ІКОНКИ
    private string GetSortIcon(string currentCol, bool isAsc, string colName, bool isTransportTable) {
        if (currentCol != colName) return "bi-arrow-down-up";
        if (isTransportTable && colName == "Status" && currentCol == "Status") { return transportStatusSortState == 0 ? "bi-arrow-up" : (transportStatusSortState == 1 ? "bi-arrow-down" : "bi-arrow-repeat"); }
        return isAsc ? "bi-arrow-up" : "bi-arrow-down";
    }

    // ДІЇ
    private async Task SaveUser() { if (editingUser != null) { Db.Users.Update(editingUser); await Db.SaveChangesAsync(); editingUser = null; await LoadData(); } }
    private async Task SaveTransport() { if (editingTransport != null) { Db.Transports.Update(editingTransport); await Db.SaveChangesAsync(); editingTransport = null; await LoadData(); } }
    private async Task SaveSession() { if (editingSession != null) { Db.RentalSessions.Update(editingSession); await Db.SaveChangesAsync(); editingSession = null; await LoadData(); } }
    private async Task DeleteUser(User user) { Db.RentalSessions.RemoveRange(Db.RentalSessions.Where(s => s.UserId == user.Id)); Db.Users.Remove(user); await Db.SaveChangesAsync(); await LoadData(); }
    private async Task DeleteTransport(Transport transport) { Db.RentalSessions.RemoveRange(Db.RentalSessions.Where(s => s.TransportId == transport.Id)); Db.Transports.Remove(transport); await Db.SaveChangesAsync(); await LoadData(); }
    private async Task DeleteSession(RentalSession session) { Db.RentalSessions.Remove(session); await Db.SaveChangesAsync(); await LoadData(); }
    
    private async Task ToggleMaintenance(Transport t) { if (t.StateCode == null) t.StateCode = ""; bool isMaintenance = t.StateCode.ToLower().Contains("рем") || t.StateCode.ToLower().Contains("maint"); if (isMaintenance) { t.StateCode = t.StateCode.Replace(" [РЕМОНТ]", "").Replace("[РЕМОНТ]", "").Trim(); } else { t.StateCode += " [РЕМОНТ]"; } Db.Transports.Update(t); await Db.SaveChangesAsync(); await LoadData(); }

    // ЛОГІКА СКАРГ
    private async Task ResolveIssue(IssueReport report) { report.IsResolved = true; Db.IssueReports.Update(report); await Db.SaveChangesAsync(); await LoadData(); }
    private async Task DeleteIssue(IssueReport report) { Db.IssueReports.Remove(report); await Db.SaveChangesAsync(); await LoadData(); }
    
    // Нова логіка: Відправити на ремонт і закрити скаргу
    private async Task SendToMaintenanceFromIssue(IssueReport report)
    {
        var t = transports.FirstOrDefault(tr => tr.Id == report.TransportId);
        if (t != null)
        {
            if (t.StateCode == null) t.StateCode = "";
            bool isMaintenance = t.StateCode.ToLower().Contains("рем") || t.StateCode.ToLower().Contains("maint");
            
            if (!isMaintenance)
            {
                t.StateCode += " [РЕМОНТ]";
                Db.Transports.Update(t);
            }
        }
        
        // Автоматично закриваємо скаргу, бо ми відреагували
        report.IsResolved = true;
        Db.IssueReports.Update(report);
        
        await Db.SaveChangesAsync();
        await LoadData();
    }
    
    private bool stringIsNullOrWhiteSpace(string value) => string.IsNullOrWhiteSpace(value);
}