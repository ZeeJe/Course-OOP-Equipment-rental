@page "/profile"
@rendermode InteractiveServer
@using BlazorApp.Data
@using BlazorApp.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject BlazorApp.Services.RentalService RentalSvc

<PageTitle>Особистий кабінет</PageTitle>

<style>
    .sortable-header {
        cursor: pointer;
        user-select: none;
        transition: background-color 0.2s;
    }
    .sortable-header:hover {
        background-color: #f8f9fa;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Особистий кабінет</h2>
    
    <div class="d-flex align-items-center" style="max-width: 350px;">
        <label class="me-2 text-muted text-nowrap">Увійти як:</label>
        <select class="form-select border-primary shadow-sm" @bind="SelectedUserId" @bind:after="LoadUserData">
            <option value="0">-- Оберіть свій профіль --</option>
            @foreach (var u in allUsers)
            {
                <option value="@u.Id">@u.Name</option>
            }
        </select>
    </div>
</div>
<hr />

@if (currentUser == null)
{
    <div class="alert alert-info shadow-sm">
        <h5 class="mb-0">Будь ласка, оберіть свій профіль у правому верхньому куті, щоб переглянути інформацію.</h5>
    </div>
}
else
{
    <div class="row mb-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg h-100 rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white p-4">
                    <h4 class="mb-0">@currentUser.Name</h4>
                    <small class="text-white-50">Клієнт #@currentUser.Id</small>
                </div>
                <div class="card-body p-4 text-center">
                    <p class="text-muted mb-1">Ваш поточний баланс</p>
                    <h1 class="display-4 fw-bold @(currentUser.Balance < 0 ? "text-danger" : "text-success") mb-4">
                        @currentUser.Balance ₴
                    </h1>

                    <div class="bg-light p-3 rounded-3 border">
                        <label class="form-label fw-bold">Поповнити рахунок:</label>
                        <div class="input-group mb-2">
                            <span class="input-group-text bg-white">₴</span>
                            <input type="number" class="form-control" @bind="topUpAmount" step="10" min="10" />
                            <button class="btn btn-success fw-bold" @onclick="TopUpBalance">Поповнити</button>
                        </div>
                        @if (showSuccessMessage)
                        {
                            <small class="text-success fw-bold">Баланс успішно поповнено!</small>
                        }
                        else
                        {
                            <small class="text-muted">Мінімальна сума поповнення: 10 ₴</small>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            
            @* --- ОНОВЛЕНИЙ БЛОК: СПИСОК АКТИВНИХ ПОЇЗДОК --- *@
            @if (activeSessions.Any())
            {
                <div class="d-flex flex-column gap-3 mb-4">
                    @foreach (var session in activeSessions)
                    {
                        <div class="card border-0 shadow-sm rounded-4 bg-primary text-white position-relative overflow-hidden">
                            <div class="position-absolute top-0 end-0 p-3 opacity-25">
                                <i class="bi bi-bicycle" style="font-size: 6rem;"></i>
                            </div>
                            <div class="card-body p-4 position-relative z-1">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div class="d-flex align-items-center">
                                        <span class="spinner-grow spinner-grow-sm text-warning me-2" role="status"></span>
                                        <h5 class="fw-bold mb-0 text-warning">Поїздка триває!</h5>
                                    </div>
                                    <span class="badge bg-white text-primary rounded-pill">#@session.Id</span>
                                </div>
                                
                                <h4 class="fw-bold mb-1">Транспорт #@session.Transport?.StateCode</h4>
                                <p class="mb-3 opacity-75 small">Тариф: @session.TariffType</p>
                                
                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <div class="bg-white bg-opacity-10 rounded-3 p-2">
                                            <small class="opacity-75 d-block" style="font-size: 0.7rem;">Час старту</small>
                                            <strong>@session.StartTime</strong>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="bg-white bg-opacity-10 rounded-3 p-2">
                                            <small class="opacity-75 d-block" style="font-size: 0.7rem;">Знижка</small>
                                            <strong>@(session.DiscountPercent > 0 ? $"-{session.DiscountPercent}%" : "Немає")</strong>
                                        </div>
                                    </div>
                                </div>
                                
                                <button class="btn btn-warning w-100 fw-bold rounded-pill text-dark shadow-sm" @onclick="() => EndMyRental(session)">
                                    <i class="bi bi-stop-circle-fill me-2"></i>Завершити поїздку
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="row g-3 h-100">
                    <div class="col-sm-6">
                        <div class="card bg-info text-white border-0 shadow-sm h-100 rounded-4">
                            <div class="card-body text-center d-flex flex-column justify-content-center">
                                <h5 class="card-title">Усього поїздок</h5>
                                <h2 class="display-5 fw-bold mb-0">@completedHistory.Count</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="card bg-secondary text-white border-0 shadow-sm h-100 rounded-4">
                            <div class="card-body text-center d-flex flex-column justify-content-center">
                                <h5 class="card-title">Витрачено коштів</h5>
                                <h2 class="display-5 fw-bold mb-0">@completedHistory.Sum(s => s.TotalCost ?? 0) ₴</h2>
                            </div>
                        </div>
                    </div>
                </div>
            }
            @* --- КІНЕЦЬ БЛОКУ АКТИВНОЇ ПОЇЗДКИ --- *@

        </div>
    </div>

    <h4 class="mb-3 fw-bold">Ваша історія поїздок</h4>
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
        @if (!completedHistory.Any())
        {
            <div class="card-body text-center p-5 text-muted">
                <h5>У вас ще немає завершених поїздок.</h5>
                <p>Перейдіть у вкладку "Інвентар", щоб орендувати свій перший транспорт!</p>
            </div>
        }
        else
        {
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="sortable-header px-4" @onclick="@(() => Sort("ID"))">
                            ID <span class="bi @GetSortIcon("ID") ms-1 text-muted" style="font-size: 0.8rem;"></span>
                        </th>
                        <th class="sortable-header" @onclick="@(() => Sort("Transport"))">
                            Транспорт <span class="bi @GetSortIcon("Transport") ms-1 text-muted" style="font-size: 0.8rem;"></span>
                        </th>
                        <th class="sortable-header" @onclick="@(() => Sort("Start"))">
                            Час початку <span class="bi @GetSortIcon("Start") ms-1 text-muted" style="font-size: 0.8rem;"></span>
                        </th>
                        <th class="sortable-header" @onclick="@(() => Sort("End"))">
                            Час завершення <span class="bi @GetSortIcon("End") ms-1 text-muted" style="font-size: 0.8rem;"></span>
                        </th>
                        <th class="sortable-header text-end px-4" @onclick="@(() => Sort("Cost"))">
                            Вартість <span class="bi @GetSortIcon("Cost") ms-1 text-muted" style="font-size: 0.8rem;"></span>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in GetSortedSessions())
                    {
                        <tr>
                            <td class="px-4 text-muted">#@s.Id</td>
                            <td>
                                <strong>@(s.Transport?.StateCode ?? "Невідомо")</strong><br>
                                <small class="text-muted">@(s.Transport is Scooter ? "Самокат" : "Велосипед")</small>
                            </td>
                            <td>@s.StartTime</td>
                            <td>@s.EndTime</td>
                            <td class="text-end px-4">
                                <span class="fw-bold text-danger">- @s.TotalCost ₴</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@code {
    private List<User> allUsers = new();
    private int SelectedUserId { get; set; } = 0;
    
    private User? currentUser;
    private List<RentalSession> userSessions = new();
    
    // ОНОВЛЕНО: Тепер це список активних поїздок
    private List<RentalSession> activeSessions = new();
    private List<RentalSession> completedHistory = new();
    
    private double topUpAmount = 100; 
    private bool showSuccessMessage = false;

    // Змінні сортування
    private string sortCol = "ID";
    private bool sortAsc = false;

    protected override async Task OnInitializedAsync()
    {
        allUsers = await Db.Users.ToListAsync();
    }

    private async Task LoadUserData()
    {
        showSuccessMessage = false; 
        
        if (SelectedUserId > 0)
        {
            currentUser = await Db.Users.FirstOrDefaultAsync(u => u.Id == SelectedUserId);
            if (currentUser != null)
            {
                userSessions = await Db.RentalSessions
                    .Include(s => s.Transport)
                    .Where(s => s.UserId == SelectedUserId)
                    .ToListAsync();
                    
                // Шукаємо ВСІ поїздки, які ще не завершені
                activeSessions = userSessions.Where(s => string.IsNullOrEmpty(s.EndTime)).ToList();
                
                // Всі завершені поїздки йдуть в історію
                completedHistory = userSessions.Where(s => !string.IsNullOrEmpty(s.EndTime)).ToList();
            }
        }
        else
        {
            currentUser = null;
            userSessions.Clear();
            completedHistory.Clear();
            activeSessions.Clear();
        }
    }

    // ОНОВЛЕНО: Метод приймає конкретну сесію для завершення
    private async Task EndMyRental(RentalSession session)
    {
        if (session != null)
        {
            await RentalSvc.CompleteRental(session);
            // Перезавантажуємо дані юзера, щоб оновити баланс і історію
            await LoadUserData();
        }
    }

    // Логіка сортування
    private void Sort(string col)
    {
        if (sortCol == col) sortAsc = !sortAsc;
        else { sortCol = col; sortAsc = true; }
    }

    private string GetSortIcon(string colName)
    {
        if (sortCol != colName) return "bi-arrow-down-up";
        return sortAsc ? "bi-arrow-up" : "bi-arrow-down";
    }

    private IEnumerable<RentalSession> GetSortedSessions()
    {
        return sortCol switch {
            "Transport" => sortAsc ? completedHistory.OrderBy(s => s.Transport?.StateCode) : completedHistory.OrderByDescending(s => s.Transport?.StateCode),
            "Start" => sortAsc ? completedHistory.OrderBy(s => s.StartTime) : completedHistory.OrderByDescending(s => s.StartTime),
            "End" => sortAsc ? completedHistory.OrderBy(s => s.EndTime) : completedHistory.OrderByDescending(s => s.EndTime),
            "Cost" => sortAsc ? completedHistory.OrderBy(s => s.TotalCost ?? 0) : completedHistory.OrderByDescending(s => s.TotalCost ?? 0),
            _ => sortAsc ? completedHistory.OrderBy(s => s.Id) : completedHistory.OrderByDescending(s => s.Id)
        };
    }

    private async Task TopUpBalance()
    {
        if (currentUser != null && topUpAmount > 0)
        {
            currentUser.Balance += topUpAmount;
            Db.Users.Update(currentUser);
            await Db.SaveChangesAsync();
            
            showSuccessMessage = true;
            topUpAmount = 100; 
            allUsers = await Db.Users.ToListAsync(); 
        }
    }
}