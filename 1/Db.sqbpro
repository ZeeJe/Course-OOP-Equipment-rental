<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="Db.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="0"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2563"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="4" parent="0"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Bicycles" custom_title="0" dock_id="3" table="4,8:mainBicycles"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">-- Вмикаємо перевірку зовнішніх ключів
PRAGMA foreign_keys = ON;

-- 1. Додаємо кількох користувачів
INSERT INTO Users (Name, Balance) VALUES 
('Олександр', 500.0),
('Марія', 150.5),
('Іван', 0.0);

-- 2. Створюємо базові записи для транспорту 
-- (ID 1 і 2 будуть самокатами, ID 3 і 4 - велосипедами)
INSERT INTO Transports (BatteryLevel, StateCode) VALUES 
(85.5, 'Available'),   -- ID 1
(12.0, 'Maintenance'), -- ID 2 (розряджений/зламаний)
(NULL, 'Available'),   -- ID 3 (велосипеду батарея не потрібна)
(NULL, 'InUse');       -- ID 4 (зараз в оренді)

-- 3. Додаємо характеристики для самокатів (прив'язка до TransportId 1 та 2)
INSERT INTO Scooters (TransportId, MotorPower, FirmwareVersion, MaxLoad, SpeedLimit) VALUES 
(1, 350, 'v1.2.4', 120, 25),
(2, 500, 'v2.0.1', 150, 30);

-- 4. Додаємо характеристики для велосипедів (прив'язка до TransportId 3 та 4)
INSERT INTO Bicycles (TransportId, FrameSize, BrakeType, HasBasket) VALUES 
(3, 'L', 'Disk', 1),     -- 1 = true (є кошик)
(4, 'M', 'V-Brake', 0);  -- 0 = false (немає кошика)

-- 5. Створюємо сесії оренди (одна завершена, одна активна)
INSERT INTO RentalSessions (UserId, TransportId, StartTime, EndTime, TotalCost) VALUES 
(1, 1, '2026-03-10 10:00:00', '2026-03-10 11:30:00', 135.0), -- Завершена оренда
(2, 4, '2026-03-12 08:15:00', NULL, NULL);                   -- Активна оренда (EndTime і TotalCost ще порожні)</sql><current_tab id="0"/></tab_sql></sqlb_project>
